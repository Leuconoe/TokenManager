<?xml version="1.0" encoding="utf-8"?>
<!-- Exclude all app data from cloud backup & device transfer (Design §7). -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="."/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="."/>
    </device-transfer>
</data-extraction-rules>
